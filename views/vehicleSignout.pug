doctype html
html
  head
    title Vehicle Sign Out
    link(rel="stylesheet", href="/css/style2.css")

  body.signOut-page
    .nav-set
      nav.navbar
        .logo ParkEase

        .nav-right
          a.logout-btn(href="/registerVehicle") Logout

      .dashboard
        .form-section
          h2 Vehicle Sign Out

          form#signOutForm(method="get", action="/signout/confirm")
            .search-row
              label(for="searchQuery") Search Ticket or Plate
              .search-controls
                input#searchQuery(
                  type="text",
                  placeholder="Ticket Number or Plate Number"
                )
                button#searchBtn.btn-submit(type="button") Search

            input#vehicleId(type="hidden", name="vehicleId")

            label Receiver Name
            input#receiverName(type="text", name="receiverName", required)

            label Client Phone Number
            input#phoneNumber(
              type="tel",
              name="phoneNumber",
              pattern="[0-9]{10}",
              title="10 digit phone number",
              required
            )

            label Gender
            select#gender(name="gender", required)
              option(value="") --Select--
              option(value="Male") Male
              option(value="Female") Female

            label NIN Number
            input#ninNumber(
              type="text",
              name="ninNumber",
              pattern="[0-9]{8,10}",
              title="8–10 digit NIN",
              required
            )
            button.btn-submit(type="submit") Generate Receipt

        aside#sidebar.sidebar
          h2 Matched Registration

          #sidebarMessage.sidebar-message
            | Search a ticket or plate to see details here.

          #sidebarDetails.sidebar-details(hidden)
            .sidebar-row
              strong Driver:
              span#sbDriver — 
            .sidebar-row
              strong Ticket:
              span#sbTicket — 
            .sidebar-row
              strong Plate:
              span#sbPlate — 
            .sidebar-row
              strong Vehicle:
              span#sbVehicle — 
            .sidebar-row
              strong Arrival:
              span#sbArrival — 
            .sidebar-row
              strong Duration:
              span#sbDuration — 
            .sidebar-row.fee-row
              strong Fee:
              span#sbFee — 
            .sidebar-row.status-row
              span#sbStatus.status-badge.pending VEHICLE READY TO CHECKOUT

          button#sbSignOut.btn-submit(type="button", disabled) Confirm Sign-Out

    script(src="/js/signOut.js")