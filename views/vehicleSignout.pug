doctype html
html
  head
    title Vehicle Sign Out
    link(rel="stylesheet", href="/css/style2.css")

  body.signOut-page
    .nav-set
      nav.navbar
        .logo ParkEase

        .nav-right
          a.logout-btn(href="/registerVehicle") Logout

      .dashboard
        .form-section
          h2 Vehicle Sign Out

          form#signOutForm(method="post", action="/signout/confirm")
            .search-row
              label(for="searchQuery") Search Ticket
              .search-controls
                input#searchQuery(
                  type="text",
                  placeholder="Ticket Number or Plate Number"
                )
                button#searchBtn.btn-submit(type="button") Search

            label Receiver Name
            input#receiverName(type="text")

            label Client Phone Number
            input#phoneNumber(
              type="text",
              name="phoneNumber",
              pattern="[0-9]{10}",
              title="10 digit phone number"
            )

            label Gender
            select#gender
              option(value="") --Select--
              option Male
              option Female

            label NIN Number
            input#ninNumber(
              type="text",
              pattern="[0-9]{8,10}",
              title="8–10 digit NIN"
            )
            button.btn-submit(type="submit") Generate Receipt

        aside#sidebar.sidebar
          h2 Matched Registration

          #sidebarMessage.sidebar-message
            | Search a ticket or plate to see details here.

          #sidebarDetails.sidebar-details(hidden)
            .sidebar-row
              strong Driver:
              span#sbDriver — #{}
            .sidebar-row
              strong Ticket:
              span#sbTicket — #{}
            .sidebar-row
              strong Plate:
              span#sbPlate — #{}
            .sidebar-row
              strong Vehicle:
              span#sbVehicle — #{}
            .sidebar-row
              strong Arrival:
              span#sbArrival — #{}
            .sidebar-row
              strong Duration:
              span#sbDuration — #{}
            .sidebar-row.fee-row
              strong Fee:
              span#sbFee — #{}
            .sidebar-row.status-row
              span#sbStatus.status-badge.pending PENDING SIGN-OUT

          button#sbSignOut.btn-submit(type="button", disabled) Confirm Sign-Out

    script(src="signOut.js")