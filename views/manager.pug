doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Manager Dashboard
    link(rel="stylesheet" href="/css/style2.css")
  body
    .dashboard-app
      // Sidebar
      aside.dashboard-sidebar
        .dashboard-sidebar__logo ParkEase

        nav.dashboard-nav
          a.active(href="/") Home
          a(href="/contact") Contact
          //- a(href="tyreClinic.html") Tyre Service
          //- a(href="batteryRegistration.html") Battery Registration

        //- .dashboard-user
        //- .dashboard-user__role #{user?.role || "Service Manager"}
        //-   .dashboard-user__email #{user?.email || "manager@example.com"}
        //-   a.logout-btn(href="/auth/login") Logout

      // Main Content
      main.dashboard-main
        header.dashboard-topbar
          h2 Manager Dashboard

        section.dashboard-content
          .cards-grid.cards-row
            .stat-card
              .stat-card__label Battery Transactions Today
              .stat-card__value #{formattedBatteryTransactionsTodayAmount || 'UGX 0'}

            .stat-card
              .stat-card__label Tyre Services Today
              .stat-card__value #{formattedTyreServiceTotal || 'UGX 0'}

            .stat-card
              .stat-card__label Batteries Registered
              .stat-card__value #{totalBatteries || 0}

          // Quick Actions
          section.quick-actions
            h3 Quick Actions

            .quick-actions__buttons
              button.quick-action-btn(onclick="window.location.href = '/battryServices'")
                | Battery Service
              button.quick-action-btn(onclick="window.location.href = '/tyreService'")
                | Tyre Service
              button.quick-action-btn(onclick="window.location.href = '/registerBattery'")
                | Battery Registration

          // Recent Service Activity
          section.recent-activities
            h3 Recent Service Activity

            table.arrivals-table
              thead
                tr
                  th Time
                  th Service
                  th Item
                  th Status
              tbody
                if recentActivities && recentActivities.length
                  each activity in recentActivities
                    tr
                      td #{activity.time}
                      td #{activity.service}
                      td #{activity.item}
                      td
                        span.status-badge.parked #{activity.status}
                else
                  tr
                    td(colspan="4") No recent service activity found

          // Available Batteries
          section.recent-arrivals
            h3 Battery Available

            table.battery-table
              thead
                tr
                  th Image
                  th Battery Type
                  th Battery Brand
                  th Battery Status
              tbody
                if allBatteries && allBatteries.length
                  each battery in allBatteries
                    tr
                      td
                        img(src="/" + battery.batteryImage alt="battery image" width="90px")
                      td #{battery.batteryType}
                      td #{battery.batteryBrand}
                      td #{battery.status}
                else
                  tr
                    td(colspan="4") No Batteries Available
  script(scr="")