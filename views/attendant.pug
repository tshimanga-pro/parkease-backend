doctype html
html(lang="en")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title Attendant Dashboard
    link(href='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css' rel='stylesheet' integrity='sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB' crossorigin='anonymous')
    link(href='https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css')
    link(rel="stylesheet" href="/css/style2.css")

  body
    .dashboard-app
      aside.dashboard-sidebar
        .dashboard-sidebar__logo ParkEase

        nav.dashboard-nav
          a.active(href="/") Home
          a(href="/registerVehicle") Register Vehicle
          a(href="#") Settings

        .dashboard-user
          .dashboard-user__role Parking Attendant
          .dashboard-user__email attendant@example.com
          a.logout-btn(href="/auth/logIn") Logout

      main.dashboard-main
        header.dashboard-topbar
          .dashboard-search
            span(aria-hidden="true") 🔍
            input#dashboardSearch(
              type="search"
              placeholder="Search vehicles, receipts..."
            )

          .dashboard-topbar__meta
            .shift-info
              span Shift
              span#shiftTime 08:00 – 16:00

            button.notification#notificationBtn(
              data-count="3"
              aria-label="Notifications"
            ) 🛎️

        section.dashboard-content
          .cards-grid.cards-row
            .stat-card
              .stat-card__label Total Vehicles Packed
              .stat-card__value#totalVehicles #{totalVehiclesPacked || 0}

            .stat-card
              .stat-card__label Today's Total Revenue (UGX)
              .stat-card__value#totalRevenue UGX 0

            .stat-card.progress-card
              .stat-card__label Available Parking Slots
              .progress-card__bar
                .progress-card__fill#slotFill
              .progress-card__label
                span#slotCount 0
                |  /
                span#slotTotal 0
                |  occupied (
                span#slotPerc 0
                | %)

          section.quick-actions
            h3 Quick Actions
            .quick-actions__buttons
              button.quick-action-btn(
                onclick="window.location.href = '/registerVehicle'"
              ) Register Vehicle

              button.quick-action-btn(
                onclick="window.location.href = '/signout'"
              ) Vehicle Sign-out

              button.quick-action-btn(
                onclick="window.print()"
              ) Print Daily Summary

          section.recent-arrivals
            h3 Recent Arrivals
            table.arrivals-table
              thead
                tr
                  th Driver Name
                  th Phone Number
                  th Vehicle Type
                  th Number Plate
                  th Vehicle Model
                  th Vehicle Color
                  th Arrival Time
                  th Status
                  th Receipt Number
                  th Actions
              tbody
                if parkedVehicles && parkedVehicles.length
                  each vehicle in parkedVehicles
                    tr
                      td #{vehicle.driverName}
                      td #{vehicle.phoneNumber}
                      td #{vehicle.vehicleType}
                      td #{vehicle.numberPlate}
                      td #{vehicle.vehicleModel}
                      td #{vehicle.vehicleColor}
                      td #{vehicle.arrivalTime}
                      td #{vehicle.status}
                      td #{vehicle.receiptNumber}
                      td
                        button.btn.btn-sm.btn-outline-primary(onclick=`navigator.clipboard.writeText("${vehicle.receiptNumber}"); alert("Receipt ${vehicle.receiptNumber} copied");`)
                          i.fa-solid.fa-copy.me-1
                          | Copy
                else
                  tr
                    td(colspan="10") No parked vehicles found
                  
                              

          section#liveFeed
            h3 Live Activity
            p.dashboard-help Updates will appear here as vehicles enter or leave.
            ul.activity-log#activityLog

    script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js' integrity='sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI' crossorigin='anonymous')
        

    script(scr="public/js/attdash.js")
