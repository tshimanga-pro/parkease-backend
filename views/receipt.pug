extends layout
block content 
  .container.min-vh-100.d-flex.justify-content-center.align-items-center
    .card.shadow-lg.border-0.rounded-4(style='width: 100%; max-width: 450px;')
      .card-body.p-5
        h2.text-center.fw-bold.mb-2 ParkEase
        p.text-center.text-muted.mb-4 Integrated Parking system!
        h5.fw-bold.text-upperCase Official Receit
        p.mb-0.font-monospace=record.receiptNumber

        //- Transaction Details
        span.text-muted Date:
        span.fw-semibold= new Date(record.signoutTime).toLocaleDateString()
        span.text-muted Date:
        span.fw-semibold= new Date(record.signoutTime).toLocaleTimeString([],{hour:"2-digit", minute:"2-digit"})
        span.text-muted Vehicle Number Plate:
        span.fw-semibold= record.vehicleId.numberPlate
        span.text-muted Vehicle Type:
        span.fw-semibold= record.vehicleId.vehicleType
        span.text-muted Receiver Name:
        span.fw-semibold= record.recciverName

        //- Financials
        
        span.fw-bold.text-upperCase Total Paid:
        span.fs.4-fw-bold.text-success UGX #{record.amountPaid.toLocalString()}
        //- Footer note
    .text-center.mt-4.mb-4
        p.small.text-muted.mb-4 Thank you for using ParkEase!
        p.small.text-muted drive Safely
        //- Print receipt
    .card-footer.bg-white.border-0.p-4.pt-0.no-Print
        button.btn.btn-primary.w-100.py-2.fw-bold.mb-2(onclik="window.print()") 
            i.fa-solid.fa-print.me-2
            | Print Receipt
        a.btn.btn-outline-secondary.w-100.fw-bold(href="/") Return Home

  script(src='https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js')